{
  "name": "@askewly/agent-design-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Agent-native code canvas for Codex and Claude terminals",
  "author": "Askewly",
  "productName": "AskewlyDesign",
  "main": "dist/main.js",
  "config": {
    "forge": "./forge.config.cjs"
  },
  "scripts": {
    "prestart": "npm run build",
    "start": "electron .",
    "prebuild": "npm --prefix ../agent-design run build && npm --prefix ../agent-design-bridge run build && npm --prefix ../../packages/agent-design-mcp run build",
    "build": "tsc -p tsconfig.json && esbuild src/preload.ts --bundle --platform=node --format=cjs --external:electron --outfile=dist/preload.cjs",
    "test": "vitest run",
    "test:supervisor": "vitest run test/bridge-supervisor.test.ts && node scripts/run-electron-supervisor-smoke.mjs",
    "test:terminal-bootstrap": "vitest run test/terminal-command.test.ts",
    "test:project-trust": "vitest run test/project-registry.test.ts",
    "test:recovery": "npm --prefix ../agent-design-bridge test -- src/desktop-recovery.test.ts",
    "test:preview-sandbox": "vitest run test/preview-security.test.ts && node scripts/run-preview-security-smoke.mjs",
    "test:diagnostics": "vitest run test/os-actions.test.ts test/diagnostics.test.ts",
    "verify:security": "node scripts/verify-security.mjs",
    "prepare:package": "npm run build && node scripts/prepare-package.mjs",
    "premake:win": "npm run prepare:package",
    "make:win": "electron-forge make --platform=win32 --arch=x64",
    "verify:package": "node scripts/verify-package.mjs",
    "pretest:packaged-e2e": "npm run make:win",
    "test:packaged-e2e": "node scripts/run-packaged-e2e.mjs && node scripts/run-installer-lifecycle.mjs",
    "test:packaged-child": "node scripts/run-packaged-child-smoke.mjs",
    "verify:packaged-evidence": "node scripts/verify-packaged-evidence.mjs"
  },
  "devDependencies": {
    "@askewly/agent-design": "file:../agent-design",
    "@askewly/agent-design-bridge": "file:../agent-design-bridge",
    "@askewly/agent-design-mcp": "file:../../packages/agent-design-mcp",
    "@askewly/canvas-core": "file:../../packages/canvas-core",
    "@doyensec/electronegativity": "1.10.3",
    "@electron-forge/cli": "7.11.2",
    "@electron-forge/maker-squirrel": "7.11.2",
    "@electron/asar": "^4.0.1",
    "@electron/fuses": "2.1.3",
    "@types/node": "^24.13.2",
    "electron": "43.1.0",
    "esbuild": "0.28.1",
    "pixelmatch": "^7.1.0",
    "png-to-ico": "3.0.2",
    "pngjs": "^7.0.0",
    "typescript": "~6.0.2",
    "vitest": "^3.2.7"
  },
  "overrides": {
    "tar": "7.5.19",
    "tmp": "0.2.7"
  }
}
