{
  "name": "glass-landing",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview --port 4173",
    "lint:design": "node ../../scripts/lint/index.js ./DESIGN.md",
    "build:design": "node ../../scripts/lint/build.js ./DESIGN.md --out ./src/theme.generated.css",
    "lint:css": "stylelint \"src/**/*.css\" --formatter json -o .design/css-lint.json || true",
    "lint:js": "eslint . --format json -o .design/eslint.json || true",
    "test:vrt": "playwright test",
    "test:vrt:update": "playwright test --update-snapshots"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "tailwindcss": "^4.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "stylelint": "^16.10.0",
    "stylelint-config-standard": "^36.0.0",
    "eslint": "^9.15.0",
    "eslint-plugin-tailwindcss": "^3.17.5",
    "@playwright/test": "^1.49.0"
  }
}
