{
  "name": "@askewly/agent-design-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "agent-design-mcp": "./dist/cli.js",
    "agent-canvas": "./dist/agent-canvas.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "types": "./dist/index.d.ts",
  "scripts": {
    "prebuild": "npm --prefix ../component-registry run build",
    "build": "tsc",
    "pretest": "npm run build",
    "test": "vitest run",
    "preroundtrip": "npm run build && npm --prefix ../agent-design-engine run build && npm --prefix ../../apps/agent-design-bridge run build",
    "roundtrip": "node scripts/run-roundtrip.mjs",
    "verify:roundtrip": "node scripts/verify-roundtrip.mjs"
  },
  "dependencies": {
    "@askewly/component-registry": "file:../component-registry",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "typescript": "~6.0.2",
    "vitest": "^3.2.7"
  }
}
