{
  "name": "@askewly/design",
  "version": "0.1.0",
  "description": "Query, inject, and verify the Askewly Design system (tokens, UI vocabulary, recipes) from your terminal or coding agent.",
  "license": "MIT",
  "homepage": "https://ui.askewly.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lumatic2/ui-dictionary.git",
    "directory": "packages/cli"
  },
  "keywords": [
    "design-system",
    "design-tokens",
    "linter",
    "ui",
    "coding-agent"
  ],
  "type": "module",
  "bin": {
    "askewly-design": "./dist/index.js"
  },
  "files": [
    "dist",
    "data",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build:data": "node scripts/build-data.mjs",
    "build": "npm run build:data && tsc",
    "test": "vitest run",
    "prepack": "npm run build"
  },
  "dependencies": {
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "yaml": "^2.6.0"
  }
}
