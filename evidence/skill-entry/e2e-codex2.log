+        --accent: #b9faf8;
+        --accent-foreground: oklch(0.16 0.015 270);
+        --border: oklch(0.88 0.015 270);
+        --ring: #6f2dbd;
+        --space-1: 4px;
+        --space-2: 8px;
+        --space-4: 16px;
+        --space-8: 32px;
+        --space-16: 64px;
+        --font-size-sm: 14px;
+        --font-size-base: 16px;
+        --font-size-lg: 20px;
+        --font-weight-regular: 400;
+        --font-weight-medium: 500;
+        --font-sans: Geist, "Noto Sans KR", ui-sans-serif, system-ui, sans-serif;
+        --radius-sm: 4px;
+        --radius-md: 6px;
+        --radius-lg: 8px;
+        --radius-xl: 12px;
+      }
+
+      :root.dark {
+        --background: oklch(0.16 0.015 270);
+        --foreground: oklch(0.985 0 0);
+        --card: oklch(0.25 0.03 270);
+        --card-foreground: oklch(0.985 0 0);
+        --primary: oklch(0.985 0 0);
+        --primary-foreground: oklch(0.16 0.015 270);
+        --secondary: oklch(0.35 0.03 270);
+        --secondary-foreground: oklch(0.95 0.015 270);
+        --muted: oklch(0.35 0.03 270);
+        --muted-foreground: oklch(0.72 0.02 270);
+        --accent: oklch(0.35 0.03 270);
+        --accent-foreground: oklch(0.985 0 0);
+        --border: oklch(0.35 0.03 270);
+        --ring: #b298dc;
+      }
+
+      *,
+      *::before,
+      *::after {
+        box-sizing: border-box;
+      }
+
+      body {
+        min-height: 100dvh;
+        margin: 0;
+        display: grid;
+        place-items: center;
+        padding: var(--space-4);
+        background: var(--background);
+        color: var(--foreground);
+        font-family: var(--font-sans);
+      }
+
+      .profile-card {
+        width: min(100%, calc(var(--space-16) * 5));
+        display: grid;
+        justify-items: center;
+        gap: var(--space-4);
+        padding: var(--space-8);
+        border: 1px solid var(--border);
+        border-radius: var(--radius-xl);
+        background: var(--card);
+        color: var(--card-foreground);
+        text-align: center;
+      }
+
+      .avatar {
+        width: var(--space-16);
+        height: var(--space-16);
+        overflow: hidden;
+        border-radius: var(--radius-lg);
+        background: var(--accent);
+        color: var(--accent-foreground);
+      }
+
+      .avatar svg {
+        display: block;
+        width: 100%;
+        height: 100%;
+      }
+
+      .identity {
+        display: grid;
+        gap: var(--space-1);
+        word-break: keep-all;
+      }
+
+      .name {
+        margin: 0;
+        font-size: var(--font-size-lg);
+        font-weight: var(--font-weight-medium);
+        line-height: 1.3;
+        text-wrap: balance;
+      }
+
+      .title {
+        margin: 0;
+        color: var(--muted-foreground);
+        font-size: var(--font-size-sm);
+        font-weight: var(--font-weight-regular);
+        line-height: 1.5;
+      }
+
+      .follow-button {
+        min-height: calc(var(--space-8) + var(--space-2));
+        padding: var(--space-2) var(--space-4);
+        border: 1px solid var(--primary);
+        border-radius: var(--radius-sm);
+        background: var(--primary);
+        color: var(--primary-foreground);
+        font: inherit;
+        font-size: var(--font-size-sm);
+        font-weight: var(--font-weight-medium);
+        line-height: 1;
+        cursor: pointer;
+        transition: opacity 160ms ease, background-color 160ms ease,
+          color 160ms ease, transform 160ms ease;
+      }
+
+      .follow-button:hover {
+        opacity: 0.9;
+      }
+
+      .follow-button:active {
+        transform: translateY(var(--space-1));
+      }
+
+      .follow-button:focus-visible {
+        outline: 3px solid color-mix(in oklch, var(--ring) 45%, transparent);
+        outline-offset: var(--space-1);
+      }
+
+      .follow-button[aria-pressed="true"] {
+        border-color: var(--border);
+        background: var(--secondary);
+        color: var(--secondary-foreground);
+      }
+
+      @media (prefers-reduced-motion: reduce) {
+        .follow-button {
+          transition: none;
+        }
+      }
+    </style>
+    <script>
+      const requestedTheme = new URLSearchParams(location.search).get("theme");
+      const prefersDark = matchMedia("(prefers-color-scheme: dark)").matches;
+
+      if (requestedTheme === "dark" || (!requestedTheme && prefersDark)) {
+        document.documentElement.classList.add("dark");
+      }
+    </script>
+  </head>
+  <body>
+    <article class="profile-card" aria-labelledby="profile-name">
+      <div class="avatar" role="img" aria-label="전유성의 아바타">
+        <svg viewBox="0 0 64 64" aria-hidden="true">
+          <rect width="64" height="64" rx="8" fill="currentColor" opacity="0.08" />
+          <circle cx="32" cy="25" r="11" fill="currentColor" opacity="0.72" />
+          <path d="M13 58c2-12 9-18 19-18s17 6 19 18" fill="currentColor" />
+        </svg>
+      </div>
+
+      <div class="identity">
+        <h1 class="name" id="profile-name">전유성</h1>
+        <p class="title">AI 빌더 · askewly</p>
+      </div>
+
+      <button class="follow-button" type="button" aria-pressed="false">
+        팔로우
+      </button>
+    </article>
+
+    <script>
+      const followButton = document.querySelector(".follow-button");
+
+      followButton.addEventListener("click", () => {
+        const isFollowing = followButton.getAttribute("aria-pressed") === "true";
+        followButton.setAttribute("aria-pressed", String(!isFollowing));
+        followButton.textContent = isFollowing ? "팔로우" : "팔로잉";
+      });
+    </script>
+  </body>
+</html>

