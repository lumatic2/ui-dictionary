\"Noto Sans KR\", ui-sans-serif, system-ui, sans-serif;\n  --radius-sm: 4px;\n  --radius-md: 6px;\n  --radius-lg: 8px;\n  --radius-xl: 12px;\n}\n\n.dark {\n  --background: oklch(0.16 0.015 270);\n  --foreground: oklch(0.985 0 0);\n  --card: oklch(0.25 0.03 270);\n  --card-foreground: oklch(0.985 0 0);\n  --secondary: oklch(0.35 0.03 270);\n  --secondary-foreground: oklch(0.95 0.015 270);\n  --muted: oklch(0.35 0.03 270);\n  --muted-foreground: oklch(0.72 0.02 270);\n  --accent: oklch(0.35 0.03 270);\n  --accent-foreground: oklch(0.985 0 0);\n  --destructive: oklch(0.58 0.22 27);\n  --border: oklch(0.35 0.03 270);\n  --input: oklch(0.35 0.03 270);\n  --ring: #B298DC;\n  --primary: oklch(0.985 0 0);\n  --primary-foreground: oklch(0.16 0.015 270);\n}\n\n* { box-sizing: border-box; }\n\nbody {\n  margin: 0;\n  min-height: 100vh;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  padding: var(--space-8);\n  background: var(--background);\n  font-family: var(--font-sans);\n  color: var(--foreground);\n}\n\n.banner {\n  width: 100%;\n  max-width: 480px;\n  background: var(--card);\n  color: var(--card-foreground);\n  border: 1px solid var(--border);\n  border-radius: var(--radius-xl);\n  padding: var(--space-12) var(--space-8);\n  text-align: center;\n}\n\n.banner__title {\n  margin: 0 0 var(--space-2);\n  font-size: var(--font-size-xl);\n  font-weight: var(--font-weight-medium);\n  word-break: keep-all;\n  overflow-wrap: break-word;\n}\n\n.banner__desc {\n  margin: 0 0 var(--space-8);\n  font-size: var(--font-size-base);\n  color: var(--muted-foreground);\n  word-break: keep-all;\n  overflow-wrap: break-word;\n}\n\nform {\n  display: flex;\n  flex-direction: column;\n  gap: var(--space-4);\n  text-align: left;\n}\n\n.field-row {\n  display: flex;\n  gap: var(--space-2);\n}\n\nlabel {\n  position: absolute;\n  width: 1px;\n  height: 1px;\n  overflow: hidden;\n  clip: rect(0 0 0 0);\n}\n\ninput[type=\"email\"] {\n  flex: 1;\n  min-width: 0;\n  padding: var(--space-2) var(--space-4);\n  font-size: var(--font-size-base);\n  font-family: inherit;\n  color: var(--foreground);\n  background: var(--background);\n  border: 1px solid var(--input);\n  border-radius: var(--radius-md);\n}\n\ninput[type=\"email\"]:focus-visible {\n  outline: 2px solid var(--ring);\n  outline-offset: 2px;\n}\n\ninput[type=\"email\"][aria-invalid=\"true\"] {\n  border-color: var(--destructive);\n}\n\ninput[type=\"email\"]:disabled {\n  background: var(--muted);\n  color: var(--muted-foreground);\n  cursor: not-allowed;\n}\n\nbutton {\n  flex-shrink: 0;\n  padding: var(--space-2) var(--space-4);\n  font-size: var(--font-size-base);\n  font-weight: var(--font-weight-medium);\n  font-family: inherit;\n  color: var(--primary-foreground);\n  background: var(--primary);\n  border: none;\n  border-radius: var(--radius-md);\n  cursor: pointer;\n  white-space: nowrap;\n  word-break: keep-all;\n  transition: opacity 120ms ease;\n}\n\nbutton:hover:not(:disabled) { opacity: 0.9; }\nbutton:active:not(:disabled) { opacity: 0.8; }\n\nbutton:focus-visible {\n  outline: 2px solid var(--ring);\n  outline-offset: 2px;\n}\n\nbutton:disabled {\n  opacity: 0.5;\n  cursor: not-allowed;\n}\n\n.message {\n  min-height: 1.25em;\n  font-size: var(--font-size-sm);\n  word-break: keep-all;\n}\n\n.message[data-state=\"error\"] {\n  color: var(--destructive);\n}\n\n.message[data-state=\"success\"] {\n  color: var(--foreground);\n  font-weight: var(--font-weight-medium);\n}\n</style>\n</head>\n<body>\n<section class=\"banner\" aria-labelledby=\"banner-title\">\n  <h2 class=\"banner__title\" id=\"banner-title\">뉴스레터를 구독해 보세요</h2>\n  <p class=\"banner__desc\">매주 한 번, 놓치기 아까운 소식만 골라 이메일로 보내드립니다.</p>\n\n  <form id=\"subscribe-form\" novalidate>\n    <div class=\"field-row\">\n      <label for=\"email\">이메일 주소</label>\n      <input\n        type=\"email\"\n        id=\"email\"\n        name=\"email\"\n        placeholder=\"you@example.com\"\n        autocomplete=\"email\"\n        required\n        aria-describedby=\"form-message\"\n      />\n      <button type=\"submit\" id=\"submit-btn\">구독하기</button>\n    </div>\n    <p class=\"message\" id=\"form-message\" role=\"status\" aria-live=\"polite\"></p>\n  </form>\n</section>\n\n<script>\n  const form = document.getElementById('subscribe-form');\n  const emailInput = document.getElementById('email');\n  const submitBtn = document.getElementById('submit-btn');\n  const message = document.getElementById('form-message');\n\n  function setMessage(text, state) {\n    message.textContent = text;\n    if (state) {\n      message.setAttribute('data-state', state);\n    } else {\n      message.removeAttribute('data-state');\n    }\n  }\n\n  function isValidEmail(value) {\n    return /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/.test(value);\n  }\n\n  form.addEventListener('submit', (e) => {\n    e.preventDefault();\n    const value = emailInput.value.trim();\n\n    if (!value) {\n      emailInput.setAttribute('aria-invalid', 'true');\n      setMessage('이메일 주소를 입력해 주세요.', 'error');\n      emailInput.focus();\n      return;\n    }\n\n    if (!isValidEmail(value)) {\n      emailInput.setAttribute('aria-invalid', 'true');\n      setMessage('이메일 형식이 올바르지 않아요. 예: you@example.com', 'error');\n      emailInput.focus();\n      return;\n    }\n\n    emailInput.removeAttribute('aria-invalid');\n    emailInput.disabled = true;\n    submitBtn.disabled = true;\n    setMessage('구독 처리 중입니다…', null);\n\n    setTimeout(() => {\n      emailInput.disabled = false;\n      submitBtn.disabled = false;\n      setMessage('구독해 주셔서 감사합니다! 확인 메일을 보내드렸어요.', 'success');\n      form.reset();\n    }, 900);\n  });\n\n  emailInput.addEventListener('input', () => {\n    if (emailInput.getAttribute('aria-invalid') === 'true') {\n      emailInput.removeAttribute('aria-invalid');\n      setMessage('', null);\n    }\n  });\n</script>\n</body>\n</html>\n","structuredPatch":[],"originalFile":null,"userModified":false}}
